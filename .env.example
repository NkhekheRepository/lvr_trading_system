# System Configuration
LVR_ENV=development
LVR_LOG_LEVEL=INFO

# Execution Mode: SIM | PAPER | LIVE
LVR_EXECUTION_MODE=SIM

# Binance Futures API
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=true

# PostgreSQL Configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=trading_system
PG_USER=trading_user
PG_PASSWORD=your_secure_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Live Trading Safety
LVR_LIVE_CONFIRMED=false

# System Limits
MAX_LEVERAGE=10
MAX_DRAWDOWN_PCT=0.10
MAX_DAILY_LOSS_PCT=0.03

# Feature Windows
RETURN_WINDOW=50
VOLATILITY_WINDOW=100
DEPTH_WINDOW=100
SPREAD_WINDOW=100

# Strategy Parameters
OFI_THRESHOLD=0.7
REGIME_THRESHOLD=2.0
SIGNAL_DECAY=0.95

# Execution Parameters
SLIPPAGE_ALPHA=0.5
SIMULATED_LATENCY_MS=100
